        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1600607688960-e095ff83135c?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Detalle de madera tallada",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1584622650111-993a426fbf0a?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Baño de época restaurado",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        alt: "Patio interior con jardín",
        class: "col-span-1 md:col-span-2 row-span-1",
        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Sala de estar común",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1631049307264-da0ec9d70304?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Balcón con vista",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    // Nuevas imágenes añadidas para completar la cuadrícula 4x3
    {
        src: "https://images.unsplash.com/photo-1554995207-c18c203602cb?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Dormitorio de lujo histórico",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    {
        src: "https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Escalera clásica",
        class: "col-span-1 row-span-1",
        hidden: false
    },
    // Imágenes ocultas para el botón "Ver Galería Completa"
    {
        src: "https://images.unsplash.com/photo-1560185007-c5ca9d2c014d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
        alt: "Fachada exterior al atardecer",
        class: "col-span-1 md:col-span-2 row-span-1",
        hidden: true
    },
    {
        src: "https://images.unsplash.com/photo-1564078516393-cf04bd966897?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80",
