---
// src/components/sections/Contact.astro
---

<section id="contacto" class="relative py-0 bg-white">
    <!-- Parallax Background Image for upper half -->
    <div class="absolute inset-x-0 top-0 h-96 overflow-hidden">
        <img
            src="https://images.unsplash.com/photo-1512918728675-ed5a9ecdebfd?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80"
            alt="Textura de madera"
            class="w-full h-full object-cover object-bottom"
        />
        <div class="absolute inset-0 bg-brand-blue/80 mix-blend-multiply"></div>
    </div>

    <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-24 pb-24"
    >
        <div class="text-center mb-12">
            <h2
                class="text-3xl md:text-5xl font-playfair font-bold text-white mb-4"
            >
                Contáctanos Hoy
            </h2>
            <p class="text-white/80 max-w-2xl mx-auto">
                ¿Tienes alguna pregunta especial sobre tu estadía? Completa el
                formulario y nuestro conserje se contactará a la brevedad.
            </p>
        </div>

        <div
            class="bg-white rounded-sm shadow-2xl overflow-hidden max-w-5xl mx-auto flex flex-col md:flex-row"
        >
            <!-- Contact Info Box -->
            <div
                class="w-full md:w-1/3 bg-brand-blue text-white p-10 relative overflow-hidden"
            >
                <!-- Abstract shape -->
                <div
                    class="absolute -bottom-24 -right-24 w-64 h-64 bg-white/5 rounded-full blur-3xl"
                >
                </div>

                <h3 class="text-2xl font-playfair font-bold mb-6">
                    Información
                </h3>

                <div class="space-y-6">
                    <div class="flex items-start">
                        <svg
                            class="w-6 h-6 text-brand-gold shrink-0 mr-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                        <p class="text-sm text-white/80">
                            Av. Principal 1234<br />Barrio Histórico, CP 9000
                        </p>
                    </div>

                    <div class="flex items-center">
                        <svg
                            class="w-6 h-6 text-brand-gold shrink-0 mr-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path></svg
                        >
                        <p class="text-sm text-white/80">+1 (800) 123-4567</p>
                    </div>

                    <div class="flex items-center">
                        <svg
                            class="w-6 h-6 text-brand-gold shrink-0 mr-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path></svg
                        >
                        <p class="text-sm text-white/80">
                            reservas@historichomes.com
                        </p>
                    </div>
                </div>
            </div>

            <!-- Form Box -->
            <div class="w-full md:w-2/3 p-10 lg:p-14">
                <form action="#" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label
                                for="name"
                                class="block text-sm font-medium text-brand-blue mb-2"
                                >Nombre Completo</label
                            >
                            <input
                                type="text"
                                id="name"
                                name="name"
                                class="w-full px-4 py-3 bg-brand-light border border-gray-200 rounded-sm focus:ring-brand-gold focus:border-brand-gold outline-none transition-colors"
                                placeholder="John Doe"
                            />
                        </div>
                        <div>
                            <label
                                for="email"
                                class="block text-sm font-medium text-brand-blue mb-2"
                                >Email</label
                            >
                            <input
                                type="email"
                                id="email"
                                name="email"
                                class="w-full px-4 py-3 bg-brand-light border border-gray-200 rounded-sm focus:ring-brand-gold focus:border-brand-gold outline-none transition-colors"
                                placeholder="john@ejemplo.com"
                            />
                        </div>
                    </div>

                    <div>
                        <label
                            for="subject"
                            class="block text-sm font-medium text-brand-blue mb-2"
                            >Asunto (Opcional)</label
                        >
                        <input
                            type="text"
                            id="subject"
                            name="subject"
                            class="w-full px-4 py-3 bg-brand-light border border-gray-200 rounded-sm focus:ring-brand-gold focus:border-brand-gold outline-none transition-colors"
                            placeholder="Dudas sobre reserva"
                        />
                    </div>

                    <div>
                        <label
                            for="message"
                            class="block text-sm font-medium text-brand-blue mb-2"
                            >Mensaje</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            class="w-full px-4 py-3 bg-brand-light border border-gray-200 rounded-sm focus:ring-brand-gold focus:border-brand-gold outline-none transition-colors resize-none"
                            placeholder="¿Cómo podemos ayudarte?"></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full bg-brand-blue text-white font-medium py-4 px-6 rounded-sm hover:bg-brand-gold focus:ring-4 focus:ring-brand-gold/30 transition-all duration-300"
                    >
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
