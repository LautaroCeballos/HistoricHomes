---
// src/components/sections/Rooms.astro

const rooms = [
  {
    title: "Suite Presidencial Histórica",
    desc: "Nuestra habitación más exclusiva. Cuenta con mobiliario del siglo XIX original, sala de estar independiente y un balcón privado con vistas a la plaza central.",
    price: "Desde $450 / noche",
    features: ["Cama King", "Balcón Privado", "Sala de Estar", "Bañera Vintage"],
    img: "https://images.unsplash.com/photo-1578683010236-d716f9a3f461?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
  },
  {
    title: "Habitación Clásica Deluxe",
    desc: "Un equilibrio perfecto entre herencia y confort. Disfruta de la luz natural que entra por los amplios ventanales restaurados y detalles en madera tallada.",
    price: "Desde $280 / noche",
    features: ["Cama Queen", "Vista al Jardín", "Wi-Fi Alta Velocidad", "Smart TV"],
    img: "https://images.unsplash.com/photo-1590490360182-c33d57733427?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
  },
  {
    title: "Estudio del Artista",
    desc: "Pensado para parejas o creativos buscando inspiración. Ubicado en el ático restaurado, ofrece privacidad total, vigas expuestas y una claraboya romántica.",
    price: "Desde $320 / noche",
    features: ["Cama King", "Claraboya", "Área de Trabajo", "Minibar Premium"],
    img: "https://images.unsplash.com/photo-1554995207-c18c203602cb?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
  }
];
---

<section id="alojamiento" class="py-24 bg-brand-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-brand-gold uppercase tracking-widest text-sm font-semibold mb-2 block">Habitaciones y Suites</span>
      <h2 class="text-3xl md:text-5xl font-playfair font-bold text-brand-blue mb-4">
        Tus Espacios de Descanso
      </h2>
      <p class="text-brand-gray max-w-2xl mx-auto text-lg">
        Cada una de nuestras estancias tiene una historia propia que contar, equipadas compeltamente para hacer de tu viaje una experiencia sublime.
      </p>
    </div>

    <div class="space-y-16">
      {rooms.map((room, index) => (
        <div class={`flex flex-col ${index % 2 !== 0 ? 'lg:flex-row-reverse' : 'lg:flex-row'} bg-white rounded-sm overflow-hidden shadow-xl group border border-gray-100`}>
          
          <!-- Imagen de la habitación -->
          <div class="w-full lg:w-1/2 overflow-hidden relative h-72 lg:h-auto">
            <img 
              src={room.img} 
              alt={room.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute top-4 right-4 bg-brand-blue text-white px-4 py-2 font-semibold tracking-wide rounded-sm shadow-md">
              {room.price}
            </div>
          </div>

          <!-- Contenido / Detalles -->
          <div class="w-full lg:w-1/2 p-8 lg:p-12 flex flex-col justify-center">
            <h3 class="text-2xl md:text-3xl font-playfair font-bold text-brand-blue mb-4">{room.title}</h3>
            <p class="text-brand-gray leading-relaxed mb-6">{room.desc}</p>
            
            <div class="grid grid-cols-2 gap-y-3 gap-x-4 mb-8">
              {room.features.map((feature) => (
                <div class="flex items-center text-sm font-medium text-brand-blue">
                   <svg class="w-4 h-4 text-brand-gold mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                   {feature}
                </div>
              ))}
            </div>

            <div class="mt-auto">
              <a 
                href="#contacto" 
                class="inline-block bg-brand-blue text-white font-medium px-8 py-3 rounded-sm hover:bg-brand-gold transition-colors duration-300 w-full md:w-auto text-center"
              >
                Reservar Ahora
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
