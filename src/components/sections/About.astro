---
// src/components/sections/About.astro
---

<section id="about" class="py-24 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row items-center gap-16">
            <!-- Image Grid -->
            <div class="w-full lg:w-1/2 relative">
                <div
                    class="relative z-10 rounded-sm overflow-hidden shadow-2xl"
                >
                    <img
                        src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Fachada de la casa histórica"
                        class="w-full h-auto object-cover"
                        loading="lazy"
                    />
                </div>

                <!-- Experience Badge -->
                <div
                    class="absolute -bottom-8 -right-8 z-20 bg-brand-blue text-white p-8 rounded-sm shadow-xl hidden md:block border-4 border-brand-light"
                >
                    <div class="text-center font-playfair">
                        <span
                            class="block text-5xl font-bold text-brand-gold mb-1"
                            >15+</span
                        >
                        <span class="block text-sm uppercase tracking-widest"
                            >Años de<br />Excelencia</span
                        >
                    </div>
                </div>
            </div>

            <!-- Text Content -->
            <div class="w-full lg:w-1/2 lg:pl-8">
                <div class="mb-4 flex items-center gap-4">
                    <div class="h-px bg-brand-gold w-12"></div>
                    <span
                        class="text-brand-gold uppercase tracking-wider text-sm font-semibold"
                        >Sobre Nosotros</span
                    >
                </div>

                <h2
                    class="text-3xl md:text-4xl font-playfair font-bold text-brand-blue mb-6 leading-tight"
                >
                    Revitalizando Hogares, Cuidando Detalles
                </h2>

                <p class="text-brand-gray text-lg mb-8 leading-relaxed">
                    Ubicado en el corazón del distrito histórico, nuestro
                    complejo es más que un simple lugar de descanso; es un viaje
                    arquitectónico en el tiempo con todas las comodidades
                    modernas que tu mereces y buscas.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-10">
                    <div>
                        <div class="mb-3 text-brand-gold">
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="text-brand-blue font-playfair font-bold text-xl mb-2"
                        >
                            Locación Central
                        </h3>
                        <p class="text-brand-gray text-sm">
                            A pocos pasos de las plazas más icónicas y la
                            cultura local.
                        </p>
                    </div>
                    <div>
                        <div class="mb-3 text-brand-gold">
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="text-brand-blue font-playfair font-bold text-xl mb-2"
                        >
                            Calidad Histórica
                        </h3>
                        <p class="text-brand-gray text-sm">
                            Todas nuestras residencias conservan el encanto del
                            siglo XIX.
                        </p>
                    </div>
                </div>

                <a
                    href="#galeria"
                    class="inline-block border-2 border-brand-blue text-brand-blue font-semibold px-8 py-3 rounded-sm hover:bg-brand-blue hover:text-white transition-colors duration-300"
                >
                    Ver la Galería
                </a>
            </div>
        </div>
    </div>
</section>
